generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  OWNER
  SALON
}

enum AvailabilitySlotStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  ARCHIVED
}

enum AvailabilitySlotServiceRestrictionMode {
  ANY
  SELECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum BookingSource {
  WEB
  PHONE
  INSTAGRAM
  IN_PERSON
  OTHER
}

enum BookingAcquisitionSource {
  DIRECT
  FACEBOOK
  GOOGLE
  INSTAGRAM
  FIRMY_CZ
  OTHER
}

enum BookingActorType {
  USER
  CLIENT
  SYSTEM
}

enum BookingActionTokenType {
  CANCEL
  RESCHEDULE
  APPROVE
  REJECT
  CALENDAR
}

enum EmailLogStatus {
  PENDING
  SENT
  FAILED
}

enum EmailLogType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
  BOOKING_REMINDER
  GENERIC
}

enum BookingSubmissionOutcome {
  SUCCESS
  FAILED
  BLOCKED
}

enum MediaStorageProvider {
  LOCAL
}

enum MediaAssetVisibility {
  PUBLIC
  PRIVATE
}

enum MediaAssetKind {
  CERTIFICATE
  SPACE
  REFERENCE
  CONTENT
}

enum MediaType {
  CERTIFICATE
  SALON_PHOTO
  PORTRAIT
  PORTRAIT_HOME
  PORTRAIT_ABOUT
  GENERAL
}

enum PricingLayout {
  LIST
  GRID
}

enum PricingIconKey {
  DROPLET
  EYE_LASHES
  LOTUS
  BRUSH
  LEAF
  LIPSTICK
  SPARK
}

enum CalendarFeedScope {
  OWNER_BOOKINGS
}

model AdminUser {
  id                        String                  @id @default(cuid())
  email                     String                  @unique
  name                      String
  role                      AdminRole
  passwordHash              String?
  isActive                  Boolean                 @default(true)
  invitedAt                 DateTime?
  lastLoginAt               DateTime?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  inviteTokens              AdminUserInviteToken[]
  createdAvailabilitySlots  AvailabilitySlot[]      @relation("AvailabilitySlotCreatedBy")
  createdBookings           Booking[]               @relation("BookingCreatedBy")
  bookingStatusHistoryItems BookingStatusHistory[]  @relation("BookingStatusHistoryActor")
  bookingRescheduleLogs     BookingRescheduleLog[]  @relation("BookingRescheduleLogActor")
  servicePriceChangeLogs    ServicePriceChangeLog[] @relation("ServicePriceChangeLogActor")
  updatedCalendarFeeds      CalendarFeed[]          @relation("CalendarFeedUpdatedBy")
  updatedSettings           Setting[]               @relation("SettingUpdatedBy")
  updatedSiteSettings       SiteSettings[]          @relation("SiteSettingsUpdatedBy")
}

model AdminUserInviteToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, usedAt, revokedAt])
}

model ServiceCategory {
  id                 String         @id @default(cuid())
  name               String
  slug               String         @unique
  description        String?
  publicName         String?
  pricingDescription String?
  pricingLayout      PricingLayout  @default(GRID)
  pricingIconKey     PricingIconKey @default(SPARK)
  sortOrder          Int            @default(0)
  pricingSortOrder   Int            @default(0)
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  services           Service[]

  @@index([isActive, sortOrder])
  @@index([isActive, pricingSortOrder])
}

model Service {
  id                       String                    @id @default(cuid())
  categoryId               String
  name                     String
  publicName               String?
  slug                     String                    @unique
  shortDescription         String?
  description              String?
  publicIntro              String?
  seoDescription           String?
  pricingShortDescription  String?
  pricingBadge             String?
  durationMinutes          Int
  priceFromCzk             Int?
  sortOrder                Int                       @default(0)
  isActive                 Boolean                   @default(true)
  isPubliclyBookable       Boolean                   @default(true)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  category                 ServiceCategory           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  allowedAvailabilitySlots AvailabilitySlotService[]
  bookings                 Booking[]
  submissionLogs           BookingSubmissionLog[]
  priceChangeLogs          ServicePriceChangeLog[]

  @@index([categoryId, isActive, isPubliclyBookable, sortOrder])
  @@index([isActive, isPubliclyBookable, sortOrder])
}

model ServicePriceChangeLog {
  id              String     @id @default(cuid())
  serviceId       String
  changedByUserId String?
  oldPriceFromCzk Int?
  newPriceFromCzk Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  service         Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  changedByUser   AdminUser? @relation("ServicePriceChangeLogActor", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([serviceId, createdAt])
  @@index([changedByUserId, createdAt])
}

model AvailabilitySlot {
  id                     String                                 @id @default(cuid())
  startsAt               DateTime
  endsAt                 DateTime
  capacity               Int                                    @default(1)
  status                 AvailabilitySlotStatus                 @default(DRAFT)
  serviceRestrictionMode AvailabilitySlotServiceRestrictionMode @default(ANY)
  publicNote             String?
  internalNote           String?
  publishedAt            DateTime?
  cancelledAt            DateTime?
  createdByUserId        String?
  createdAt              DateTime                               @default(now())
  updatedAt              DateTime                               @updatedAt
  createdByUser          AdminUser?                             @relation("AvailabilitySlotCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  allowedServices        AvailabilitySlotService[]
  bookings               Booking[]
  submissionLogs         BookingSubmissionLog[]

  @@index([status, startsAt])
  @@index([serviceRestrictionMode, startsAt])
  @@index([startsAt, endsAt])
  @@index([createdByUserId])
}

model AvailabilitySlotService {
  slotId    String
  serviceId String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  slot      AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  service   Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([slotId, serviceId])
  @@index([serviceId, slotId])
}

model Client {
  id             String                 @id @default(cuid())
  fullName       String
  email          String                 @unique
  phone          String?
  internalNote   String?
  isActive       Boolean                @default(true)
  lastBookedAt   DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  bookings       Booking[]
  emailLogs      EmailLog[]
  submissionLogs BookingSubmissionLog[]

  @@index([phone])
  @@index([isActive, fullName])
}

model Booking {
  id                       String                    @id @default(cuid())
  clientId                 String
  slotId                   String
  serviceId                String
  source                   BookingSource             @default(WEB)
  acquisitionSource        BookingAcquisitionSource?
  acquisitionReferrerHost  String?
  acquisitionUtmSource     String?
  acquisitionUtmMedium     String?
  acquisitionUtmCampaign   String?
  isManual                 Boolean                   @default(false)
  manualOverride           Boolean                   @default(false)
  status                   BookingStatus             @default(PENDING)
  clientNameSnapshot       String
  clientEmailSnapshot      String
  clientPhoneSnapshot      String?
  serviceNameSnapshot      String
  serviceDurationMinutes   Int
  servicePriceFromCzk      Int?
  scheduledStartsAt        DateTime
  scheduledEndsAt          DateTime
  clientNote               String?
  internalNote             String?
  confirmedAt              DateTime?
  reminder24hQueuedAt      DateTime?
  reminder24hSentAt        DateTime?
  cancelledAt              DateTime?
  completedAt              DateTime?
  rescheduledAt            DateTime?
  rescheduleCount          Int                       @default(0)
  rescheduledFromBookingId String?                   @unique
  createdByUserId          String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  client                   Client                    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  slot                     AvailabilitySlot          @relation(fields: [slotId], references: [id], onDelete: Restrict)
  service                  Service                   @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  createdByUser            AdminUser?                @relation("BookingCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  rescheduledFromBooking   Booking?                  @relation("BookingRescheduleChain", fields: [rescheduledFromBookingId], references: [id], onDelete: SetNull)
  rescheduledToBooking     Booking?                  @relation("BookingRescheduleChain")
  statusHistory            BookingStatusHistory[]
  rescheduleLogs           BookingRescheduleLog[]
  actionTokens             BookingActionToken[]
  emailLogs                EmailLog[]
  submissionLogs           BookingSubmissionLog[]

  @@index([slotId, status])
  @@index([clientId, createdAt])
  @@index([serviceId, scheduledStartsAt])
  @@index([status, scheduledStartsAt])
  @@index([status, reminder24hSentAt, scheduledStartsAt])
  @@index([status, reminder24hQueuedAt, scheduledStartsAt])
  @@index([source, createdAt])
  @@index([acquisitionSource, createdAt])
  @@index([createdByUserId])
  @@index([rescheduledAt])
}

model BookingRescheduleLog {
  id              String     @id @default(cuid())
  bookingId       String
  oldStartAt      DateTime
  oldEndAt        DateTime
  newStartAt      DateTime
  newEndAt        DateTime
  changedByUserId String?
  changedByClient Boolean    @default(false)
  reason          String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  booking         Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  changedByUser   AdminUser? @relation("BookingRescheduleLogActor", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt])
  @@index([changedByUserId, createdAt])
}

model BookingStatusHistory {
  id          String           @id @default(cuid())
  bookingId   String
  status      BookingStatus
  actorType   BookingActorType
  actorUserId String?
  reason      String?
  note        String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  booking     Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actorUser   AdminUser?       @relation("BookingStatusHistoryActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt])
  @@index([actorUserId, createdAt])
}

model BookingActionToken {
  id         String                 @id @default(cuid())
  bookingId  String
  type       BookingActionTokenType
  tokenHash  String                 @unique
  expiresAt  DateTime
  usedAt     DateTime?
  revokedAt  DateTime?
  lastSentAt DateTime?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  booking    Booking                @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  emailLogs  EmailLog[]

  @@index([bookingId, type, expiresAt])
  @@index([expiresAt])
}

model EmailLog {
  id                  String              @id @default(cuid())
  bookingId           String?
  clientId            String?
  actionTokenId       String?
  type                EmailLogType
  status              EmailLogStatus      @default(PENDING)
  attemptCount        Int                 @default(0)
  nextAttemptAt       DateTime            @default(now())
  processingStartedAt DateTime?
  processingToken     String?
  recipientEmail      String
  subject             String
  templateKey         String
  payload             Json?
  provider            String?
  providerMessageId   String?
  errorMessage        String?
  sentAt              DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  booking             Booking?            @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  client              Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  actionToken         BookingActionToken? @relation(fields: [actionTokenId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt])
  @@index([clientId, createdAt])
  @@index([actionTokenId, createdAt])
  @@index([status, createdAt])
  @@index([status, nextAttemptAt])
  @@index([processingStartedAt])
  @@index([providerMessageId])
}

model BookingSubmissionLog {
  id            String                   @id @default(cuid())
  bookingId     String?
  clientId      String?
  serviceId     String?
  slotId        String?
  ipHash        String?
  emailHash     String?
  outcome       BookingSubmissionOutcome
  failureCode   String?
  failureReason String?
  userAgent     String?
  metadata      Json?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  booking       Booking?                 @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  client        Client?                  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  service       Service?                 @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  slot          AvailabilitySlot?        @relation(fields: [slotId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt])
  @@index([clientId, createdAt])
  @@index([serviceId, createdAt])
  @@index([slotId, createdAt])
  @@index([ipHash, createdAt])
  @@index([emailHash, createdAt])
  @@index([outcome, createdAt])
}

model Setting {
  id              String     @id @default(cuid())
  key             String     @unique
  value           Json
  description     String?
  updatedByUserId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  updatedByUser   AdminUser? @relation("SettingUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedByUserId])
}

model SiteSettings {
  id                       String     @id @default("site-settings")
  salonName                String
  addressLine              String
  city                     String
  postalCode               String
  phone                    String
  contactEmail             String
  instagramUrl             String?
  bookingMinAdvanceHours   Int        @default(2)
  bookingMaxAdvanceDays    Int        @default(90)
  bookingCancellationHours Int        @default(48)
  notificationAdminEmail   String
  emailSenderName          String
  emailSenderEmail         String
  emailFooterText          String?
  updatedByUserId          String?
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
  updatedByUser            AdminUser? @relation("SiteSettingsUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedByUserId])
}

model CalendarFeed {
  id              String            @id @default(cuid())
  scope           CalendarFeedScope @unique
  tokenSalt       String
  isActive        Boolean           @default(false)
  rotatedAt       DateTime?
  revokedAt       DateTime?
  updatedByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  updatedByUser   AdminUser?        @relation("CalendarFeedUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedByUserId])
}

model MediaAsset {
  id                   String               @id @default(cuid())
  storageProvider      MediaStorageProvider @default(LOCAL)
  visibility           MediaAssetVisibility @default(PUBLIC)
  kind                 MediaAssetKind
  type                 MediaType            @default(CERTIFICATE)
  originalFilename     String
  fileName             String
  storedFilename       String
  mimeType             String
  extension            String
  sizeBytes            Int
  size                 Int
  width                Int?
  height               Int?
  alt                  String?
  altText              String?
  title                String?
  storagePath          String               @unique
  url                  String
  optimizedStoragePath String?              @unique
  optimizedUrl         String?
  optimizedMimeType    String?
  optimizedWidth       Int?
  optimizedHeight      Int?
  optimizedSize        Int?
  thumbnailStoragePath String?              @unique
  thumbnailUrl         String?
  thumbnailMimeType    String?
  thumbnailWidth       Int?
  thumbnailHeight      Int?
  thumbnailSize        Int?
  sortOrder            Int?
  isPublished          Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([type, isPublished, sortOrder])
  @@index([type, createdAt])
  @@index([kind, createdAt])
  @@index([visibility, kind, createdAt])
  @@index([storageProvider, kind, createdAt])
}
